digraph SeismicScoreTriadicCirculation {
  graph [
    rankdir=LR,
    labelloc="t",
    label="Seismic Score Dashboard v0.1\n発信者・利用者・プラットフォームの三者循環図",
    fontsize=20,
    pad=0.3,
    nodesep=0.5,
    ranksep=0.8
  ];

  node [
    shape=box,
    style="rounded,filled",
    fillcolor="white",
    color="#666666",
    fontname="Helvetica"
  ];

  edge [
    color="#666666",
    arrowsize=0.8,
    fontname="Helvetica",
    fontsize=10
  ];

  Creator [
    label="発信者\n\n・定義を置く\n・構造を磨く\n・震源を残す",
    fillcolor="#f6f8fa"
  ];

  User [
    label="利用者\n\n・一次震源を選ぶ\n・良質な知へ接続する\n・コスト効率を判断する",
    fillcolor="#f6f8fa"
  ];

  Platform [
    label="プラットフォーム\n\n・利用を計測する\n・引用 / trace を保持する\n・還元候補を管理する",
    fillcolor="#f6f8fa"
  ];

  TraceLayer [
    label="Trace / Provenance Layer\n\nアクセス・引用・派生・監査の痕跡",
    fillcolor="#fff7e6"
  ];

  Dashboard [
    label="Seismic Score Dashboard\n\nOrigin / Trace / Resonance /\nPurity / Return",
    shape=ellipse,
    fillcolor="#eaf3ff"
  ];

  GovernanceBridge [
    label="Governance Bridge\n\nreview / dispute / readiness /\nhandoff judgment",
    fillcolor="#f3e8ff"
  ];

  RoyaltyOS [
    label="Royalty OS\n\n配分判断 / 保留 / 還元処理",
    fillcolor="#e8fff1"
  ];

  Creator -> Platform [label="公開 / 投稿 / 定義配置"];
  Creator -> TraceLayer [label="起点情報 / 初出痕跡"];

  User -> Platform [label="検索 / 参照 / 利用"];
  User -> TraceLayer [label="利用痕跡 / citation / ingestion"];

  Platform -> TraceLayer [label="イベント記録"];
  TraceLayer -> Dashboard [label="痕跡を供給"];

  Dashboard -> Creator [label="震源性 / 共鳴 / 構造純度を可視化"];
  Dashboard -> User [label="一次震源 / 明快さ / コスパを可視化"];
  Dashboard -> Platform [label="観測結果 / 分配候補信号"];

  Dashboard -> GovernanceBridge [label="score / readiness / flags"];
  GovernanceBridge -> RoyaltyOS [label="制度判断用 handoff"];

  RoyaltyOS -> Creator [label="還元 / 配分候補 / 記録"];
  RoyaltyOS -> Platform [label="制度結果 / 配分状態"];
  RoyaltyOS -> User [label="良質な震源への再接続"];

  Creator -> User [label="構造化された知を提供", style=dashed];
  User -> Creator [label="利用 / 共鳴 / 派生", style=dashed];
  Platform -> Creator [label="可視化 / 分析 / 候補通知", style=dashed];
}

SVG化するならコマンドはこれです。

dot -Tsvg docs/triadic-circulation.dot -o docs/triadic-circulation.svg

PNGならこちらです。

dot -Tpng docs/triadic-circulation.dot -o docs/triadic-circulation.png
